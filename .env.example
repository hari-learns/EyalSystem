SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

# Server-side only. Never expose this in frontend code.
RESEND_API_KEY=

# Use onboarding@resend.dev for Resend test mode, then switch to a verified domain sender.
ORDER_EMAIL_FROM="Eyal Orders <onboarding@resend.dev>"

# Fallback recipient when stores.merchant_order_email is empty.
ORDER_EMAIL_TO=

# Comma-separated owner login emails allowed to view platform reports.
PLATFORM_OWNER_EMAILS=

# Final deployed origin used for QR generation, for example https://example.vercel.app.
NEXT_PUBLIC_SITE_URL=
