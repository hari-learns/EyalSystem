{
  "name": "eyal-merchant-storefront",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:push": "supabase db push",
    "db:seed": "supabase db query --file supabase/seed.sql --linked",
    "db:seed:local": "supabase db query --file supabase/seed.sql --local",
    "db:reset": "supabase db reset",
    "merchant:setup": "node --env-file=.env.local scripts/setup-merchant.mjs"
  },
  "dependencies": {
    "@supabase/server": "^1.2.0",
    "@supabase/supabase-js": "^2.109.0",
    "lucide-react": "^0.561.0",
    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.16.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3"
  }
}
